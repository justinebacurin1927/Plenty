{
  "expo": {
    "owner": "justine7417",
    "name": "Plenty",
    "slug": "Plenty",
    "version": "1.0.0",
    "runtimeVersion": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#E6F4FE"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Plenty uses your location to fetch local weather and adjust hydration reminders on hot days."
      }
    },
    "android": {
      "package": "com.justine7417.plenty",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#4A90D9"
        }
      ],
      "expo-font",
      "expo-sharing",
      "expo-location",
      "expo-document-picker",
      "./plugins/withPlentyWidget",
      "expo-health-connect"
    ],
    "extra": {
      "eas": {
        "projectId": "7c4df0d9-0871-479d-a540-b253bdb76dac"
      }
    }
  }
}
